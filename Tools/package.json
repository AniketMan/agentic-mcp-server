{
  "name": "agentic-mcp-server",
  "version": "2.0.0",
  "description": "Dual-path MCP server for Unreal Engine 5 — live editor connection with offline binary injector fallback. Works with Claude Code, Cursor, Windsurf, Manus, and any MCP client.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "unreal-engine",
    "ue5",
    "blueprint",
    "game-development",
    "editor-integration",
    "ai-agent",
    "agentic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AniketMan/ue56-level-editor.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
